# ============================================================
# VERSION CONTROL
# ============================================================
.git
.gitignore
.dockerignore

# ============================================================
# DATASETS & LARGE FILES
# ============================================================
data/
dataset/
archive.zip
image_ids_and_rotation.csv
image_list.txt
unseen_test/*.png
*.csv

# ============================================================
# MODEL CHECKPOINTS (copy only what's needed)
# ============================================================
checkpoints/
*.pth
*.pt
*.ckpt

# ============================================================
# PYTHON CACHE
# ============================================================
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# ============================================================
# VIRTUAL ENVIRONMENTS
# ============================================================
venv/
env/
.venv/

# ============================================================
# IDE & EDITOR
# ============================================================
.vscode/
.idea/
*.swp
*.swo

# ============================================================
# OS FILES
# ============================================================
.DS_Store
Thumbs.db

# ============================================================
# EXPERIMENT TRACKING
# ============================================================
mlruns/
wandb/
outputs/
stego_images/

# ============================================================
# TESTING & COVERAGE
# ============================================================
.mypy_cache/
.pytest_cache/
.coverage
htmlcov/

# ============================================================
